# --- Database ---
DATABASE_URL="postgresql://user:password@localhost:5432/hotel_system?schema=public" 
# --- Replace the "user" with the name of ur username in postgreSQL and "password" with your actual database password --- #

# --- Auth ---
JWT_SECRET="replace-with-a-long-random-string"

# --- Cloudinary (room/hotel image uploads) ---
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# --- M-Pesa Daraja (Safaricom) ---
# Get sandbox credentials at https://developer.safaricom.co.ke
MPESA_ENV="sandbox" # sandbox | production
MPESA_CONSUMER_KEY=""
MPESA_CONSUMER_SECRET=""
MPESA_SHORTCODE="174379"
MPESA_PASSKEY=""
MPESA_CALLBACK_URL="https://your-domain.com/api/payments/mpesa/callback"

# --- Card payments (sandbox placeholder, e.g. Stripe/Flutterwave/Pesapal) ---
CARD_PAYMENTS_PROVIDER="mock" # mock | stripe | flutterwave | pesapal
CARD_PAYMENTS_SECRET_KEY=""

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_HOTEL_NAME="Amara Hotel & Residences"
